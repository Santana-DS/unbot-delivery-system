// =============================================================================
// include/secrets.h.example
//
// UnBot Delivery — ESP32 Firmware Credential Template
// -----------------------------------------------------------------------------
// HOW TO USE:
//   1. Copy this file:   cp include/secrets.h.example include/secrets.h
//   2. Fill in the real values below.
//   3. NEVER commit secrets.h — it is listed in .gitignore.
//      This .example file is the only credential artifact that enters git.
//
// SECURITY MODEL:
//   All credentials are stored in a single header that is included only by
//   mqtt_manager.cpp. No credential string ever appears in any other source
//   file. If credentials rotate, only this file changes.
//
//   On a production device, prefer storing these in NVS (Non-Volatile Storage)
//   via the Preferences library so they survive firmware OTA updates without
//   requiring a re-flash. That migration path is noted in mqtt_manager.cpp.
// =============================================================================

#pragma once

// -----------------------------------------------------------------------------
// Wi-Fi credentials
// The ESP32 will try to connect to this network on boot. If connection fails,
// the firmware retries with exponential backoff — see MqttManager::tick().
// -----------------------------------------------------------------------------
#define WIFI_SSID     "YOUR_WIFI_SSID_HERE"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD_HERE"

// -----------------------------------------------------------------------------
// AWS / Mosquitto broker — plain TCP (port 1883, no TLS)
//
// For V2.0 the broker is the Mosquitto instance on the AWS EC2 machine.
// MQTT_BROKER_IP is the public IPv4 of that EC2 instance (e.g. "3.22.171.3").
// Do NOT use a hostname here unless you have mDNS / DNS resolution working on
// the ESP32 — plain IP is more reliable on campus Wi-Fi with captive portals.
//
// V3.0 TODO: Migrate to port 8883 with TLS + client certificates.
//   - Add a CA cert string (PEM format) and pass it to WiFiClientSecure.
//   - Rotate MQTT credentials and store them in NVS.
// -----------------------------------------------------------------------------
#define MQTT_BROKER_IP   "YOUR_EC2_PUBLIC_IP_HERE"   // e.g. "3.22.171.3"
#define MQTT_BROKER_PORT 1883

// M2M credentials created by setup_mosquitto.sh (esp32 user)
#define MQTT_USERNAME "esp32"
#define MQTT_PASSWORD "YOUR_ESP32_MQTT_PASSWORD_HERE"

// Client ID must be unique per device on the broker.
// If you deploy multiple ESP32 units, append the MAC address:
//   String clientId = "unbot-esp32-" + WiFi.macAddress();
#define MQTT_CLIENT_ID "unbot-esp32-lock-01"
