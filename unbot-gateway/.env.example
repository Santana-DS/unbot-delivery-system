# UnBot Gateway — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── MQTT broker (Mosquitto on cloud VM) ───────────────────────────────────────
MQTT_HOST=<your-vm-public-ip>
MQTT_PORT=1883
MQTT_USER=gateway
MQTT_PASSWORD=changeme_gateway
MQTT_CLIENT_ID=unbot-gateway

# ── HTTP API listener ─────────────────────────────────────────────────────────
HTTP_ADDR=:8080
